{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.product-planner.dev/opportunity-handoff/v1.json",
  "title": "Opportunity handoff v1",
  "description": "Portable, evidence-first handoff from Scout to Product Planner.",
  "type": "object",
  "required": ["schema_version", "opportunity", "scores", "evidence"],
  "properties": {
    "schema_version": {"const": "opportunity-handoff/v1"},
    "opportunity": {
      "type": "object",
      "required": ["id", "title", "problem", "target_user", "proposed_solution"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "title": {"type": "string", "minLength": 1},
        "problem": {"type": "string", "minLength": 1},
        "target_user": {"type": "string", "minLength": 1},
        "proposed_solution": {"type": "string", "minLength": 1},
        "constraints": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": true
    },
    "scores": {
      "type": "object",
      "required": ["demand", "competition", "feasibility", "differentiation", "ecosystem_value"],
      "additionalProperties": {"$ref": "#/$defs/score"}
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/evidence"}
    },
    "assumptions": {"type": "array", "items": {"type": "string"}},
    "unknowns": {"type": "array", "items": {"type": "string"}},
    "metadata": {"type": "object"}
  },
  "$defs": {
    "score": {
      "type": "object",
      "required": ["score", "confidence", "rationale"],
      "properties": {
        "score": {"type": ["number", "null"], "minimum": 0, "maximum": 100},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "rationale": {"type": "string", "minLength": 1},
        "unknown": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "evidence": {
      "type": "object",
      "required": ["id", "claim", "source", "observed_at"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "claim": {"type": "string", "minLength": 1},
        "source": {"type": "string", "minLength": 1},
        "url": {"type": "string"},
        "observed_at": {"type": "string", "minLength": 1},
        "strength": {"enum": ["strong", "moderate", "weak"]},
        "limitations": {"type": "string"}
      },
      "additionalProperties": true
    }
  }
}
